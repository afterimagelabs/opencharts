# Vite-injected env vars used by the SPA. Copy to `.env.local`
# (gitignored) and fill in. ALSO set these in the Cloudflare Pages
# project env vars (Production + Preview).
#
# When these are missing the public timeline still renders, but the
# authoring panel (sign in to add notes) quietly disables itself.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon-key...
